# DCP configuration — copy to .env and fill in. Never commit .env.
DCP_MODEL_PROVIDER=openai          # openai | anthropic | local | transformers | mock
DCP_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DCP_DATABASE_URL=sqlite:///./dcp.db

# local / self-hosted models (vLLM, Ollama, LM Studio, TGI) via an OpenAI-compatible endpoint:
#   DCP_MODEL_PROVIDER=local
#   DCP_MODEL=llama3.1                 # the model name your server serves
#   DCP_BASE_URL=http://localhost:11434/v1   # e.g. Ollama; vLLM: http://localhost:8000/v1
#   DCP_LOCAL_API_KEY=                 # usually unnecessary
DCP_BASE_URL=

# in-process open-source models (Qwen3) via HuggingFace transformers — pip install "dcp[transformers]":
#   DCP_MODEL_PROVIDER=transformers
#   DCP_MODEL=Qwen/Qwen3-4B            # any HF causal-LM repo id (no key, no server)
