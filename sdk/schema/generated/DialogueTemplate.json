{
  "$comment": "GENERATED from dcp.schema (Pydantic v2) \u2014 do not edit; run scripts/gen_schema.py.",
  "$defs": {
    "Edge": {
      "additionalProperties": false,
      "description": "A flow edge \u2014 an allowed succession between roles (SPEC \u00a72.6; TBD-11).\n\n``condition`` is free-text guidance (not machine-evaluated): at a branch it is shown to the\norchestrator's model to help it choose among the allowed next roles.",
      "properties": {
        "condition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Condition"
        },
        "from_role": {
          "minLength": 1,
          "title": "From Role",
          "type": "string"
        },
        "to_role": {
          "minLength": 1,
          "title": "To Role",
          "type": "string"
        }
      },
      "required": [
        "from_role",
        "to_role"
      ],
      "title": "Edge",
      "type": "object"
    },
    "Flow": {
      "additionalProperties": false,
      "description": "A succession graph \u2014 may be non-linear (branches, loops) (SPEC \u00a72.6).\n\nThe **initial/default** order, not a rigid script: advisory under ``mode=plan`` (a hint), and\nguiding under ``mode=flow`` (succession is constrained to the edges; deterministic when a role\nhas one outgoing edge, model-chosen among the allowed roles at a branch). Either way the\noversight loop may adapt the realized path (e.g. switch to an alternative when a candidate isn't\nready).",
      "properties": {
        "edges": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Edge"
          },
          "title": "Edges",
          "type": "array"
        },
        "entry": {
          "minLength": 1,
          "title": "Entry",
          "type": "string"
        }
      },
      "required": [
        "entry"
      ],
      "title": "Flow",
      "type": "object"
    },
    "HumanPolicy": {
      "additionalProperties": false,
      "description": "Per-role wait window + timeout behavior for waited human roles (SPEC \u00a72.8; TBD-14).",
      "properties": {
        "on_timeout": {
          "$ref": "#/$defs/OnTimeout",
          "default": "finalize_provisional"
        },
        "wait_window_seconds": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wait Window Seconds"
        }
      },
      "title": "HumanPolicy",
      "type": "object"
    },
    "ModelBinding": {
      "additionalProperties": false,
      "description": "Which model backs a consumer (D7/D8; SPEC \u00a74.5b). No credential field \u2014\nthe API key is resolved from the environment by ``provider`` (D8 / TBD-30).",
      "properties": {
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "provider": {
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "ModelBinding",
      "type": "object"
    },
    "OnTimeout": {
      "description": "Human-policy timeout behavior (SPEC \u00a72.8; TBD-14 confirmed).",
      "enum": [
        "continue",
        "finalize_provisional"
      ],
      "title": "OnTimeout",
      "type": "string"
    },
    "Orchestration": {
      "additionalProperties": false,
      "description": "Template orchestration settings (SPEC \u00a72.6). Optional model_binding is the\ntemplate-level orchestrator default (D8); env/instance may override.",
      "properties": {
        "mode": {
          "$ref": "#/$defs/OrchestrationMode",
          "default": "plan"
        },
        "model_binding": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelBinding"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "Orchestration",
      "type": "object"
    },
    "OrchestrationMode": {
      "description": "Orchestration mode (SPEC \u00a72.6; TBD-12 confirmed).",
      "enum": [
        "plan",
        "flow"
      ],
      "title": "OrchestrationMode",
      "type": "string"
    },
    "ResponseRequirement": {
      "description": "Per-role wait/mandate policy (SPEC \u00a71.4; renamed from ``response_mode``; TBD-5).",
      "enum": [
        "required",
        "optional",
        "gate"
      ],
      "title": "ResponseRequirement",
      "type": "string"
    },
    "Role": {
      "additionalProperties": false,
      "description": "A dialogue-local identity defined by a template, filled by casting (SPEC \u00a71.4).",
      "properties": {
        "binding": {
          "$ref": "#/$defs/RoleBinding"
        },
        "human_policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/HumanPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "$ref": "#/$defs/RoleKind"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "persona": {
          "default": "",
          "title": "Persona",
          "type": "string"
        },
        "response_requirement": {
          "$ref": "#/$defs/ResponseRequirement",
          "default": "optional"
        },
        "role_id": {
          "minLength": 1,
          "title": "Role Id",
          "type": "string"
        }
      },
      "required": [
        "role_id",
        "name",
        "kind"
      ],
      "title": "Role",
      "type": "object"
    },
    "RoleBinding": {
      "additionalProperties": false,
      "description": "A Role's intended participant (SPEC \u00a71.4). Empty => cast by capability/persona.",
      "properties": {
        "participant_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Participant Id"
        }
      },
      "title": "RoleBinding",
      "type": "object"
    },
    "RoleKind": {
      "description": "Role/Participant kind (SPEC \u00a71.4/\u00a71.5; TBD-4 confirmed).",
      "enum": [
        "agent",
        "human"
      ],
      "title": "RoleKind",
      "type": "string"
    },
    "TerminationPolicy": {
      "additionalProperties": false,
      "description": "Template termination policy (SPEC \u00a74.1).",
      "properties": {
        "condition": {
          "title": "Condition",
          "type": "string"
        },
        "max_turns": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Turns"
        },
        "token_budget": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token Budget"
        }
      },
      "required": [
        "condition"
      ],
      "title": "TerminationPolicy",
      "type": "object"
    },
    "Visibility": {
      "description": "Instance visibility (SPEC \u00a71.6; D5).",
      "enum": [
        "public",
        "unlisted",
        "private"
      ],
      "title": "Visibility",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Reusable, registerable dialogue definition (SPEC \u00a71.2/\u00a74.1; D1). Immutable per version.",
  "properties": {
    "allow_open_mic": {
      "default": false,
      "title": "Allow Open Mic",
      "type": "boolean"
    },
    "default_visibility": {
      "anyOf": [
        {
          "$ref": "#/$defs/Visibility"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "flow": {
      "anyOf": [
        {
          "$ref": "#/$defs/Flow"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "goal": {
      "default": "",
      "title": "Goal",
      "type": "string"
    },
    "human_policy_defaults": {
      "anyOf": [
        {
          "$ref": "#/$defs/HumanPolicy"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "orchestration": {
      "$ref": "#/$defs/Orchestration"
    },
    "roles": {
      "items": {
        "$ref": "#/$defs/Role"
      },
      "title": "Roles",
      "type": "array"
    },
    "template_id": {
      "minLength": 1,
      "title": "Template Id",
      "type": "string"
    },
    "termination_policy": {
      "$ref": "#/$defs/TerminationPolicy"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "topic": {
      "default": "",
      "title": "Topic",
      "type": "string"
    },
    "version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "template_id",
    "version",
    "title",
    "termination_policy"
  ],
  "title": "DialogueTemplate",
  "type": "object"
}
